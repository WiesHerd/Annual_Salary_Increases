# Supabase (Phase 1 team workspace) — optional
# Create a project at https://supabase.com, then copy Project URL + anon public key.
# Run supabase/migrations/001_phase1_team_enterprise.sql in the SQL editor.
# Enable Email auth under Authentication → Providers.
#
# When unset, Meritly runs in local-only mode (localStorage + manual backup).

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-key

# Auth UX (team / enterprise defaults)
VITE_ALLOW_PUBLIC_SIGNUP=false
# Optional hospital label on login panel, e.g. "Acme Health System"
# VITE_AUTH_ORG_LABEL=Acme Health System
# VITE_AUTH_REDIRECT_URL=http://localhost:5173
